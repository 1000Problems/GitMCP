{
  "name": "git-mcp-server",
  "version": "0.1.0",
  "description": "Local MCP server giving Claude native git access — wraps git CLI in MCP tools via stdio transport",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:int": "vitest run --dir tests/integration"
  },
  "keywords": ["mcp", "git", "claude"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.14.1"
  }
}
